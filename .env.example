# PostgreSQL used by Docker Compose and accessible from pgAdmin4.
POSTGRES_DB=nexus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5432
SEED_DEMO_DATA=false
NEXUSOPS_AI_MODE=live
NEXUSOPS_DEMO_MODE=false
NEXUSOPS_ENABLE_MOCK_APIS=false

# Optional: only required when enabling live FPT AI Factory calls.
FPT_AI_BASE_URL=https://mkp-api.fptcloud.com/v1
FPT_AI_API_KEY=
FPT_AI_TIMEOUT_SECONDS=60
FPT_AI_MAX_RETRIES=2
