NEXUSOPS_RAG_DATA_PATH=./final_rag_data_normalized_v1.json
NEXUSOPS_CONFIG_DIR=./configs
NEXUSOPS_RUNTIME_DIR=./runtime
NEXUSOPS_DEMO_MODE=true
NEXUSOPS_AI_MODE=deterministic
NEXUSOPS_ALLOW_REVIEW_REQUIRED=false
FPT_AI_BASE_URL=https://mkp-api.fptcloud.com/v1
FPT_AI_API_KEY=
FPT_AI_TIMEOUT_SECONDS=60
FPT_AI_MAX_RETRIES=2

# Model IDs must match FPT AI Factory /v1/models exactly.
NEXUSOPS_PLANNER_FALLBACK_MODEL=DeepSeek-V4-Flash
NEXUSOPS_PRODUCT_MODEL=SaoLa3.1-medium
NEXUSOPS_CREDIT_MODEL=Qwen3.6-27B
NEXUSOPS_COMPLIANCE_MODEL=Llama-3.3-70B-Instruct
NEXUSOPS_CRITIC_MODEL=gpt-oss-120b
NEXUSOPS_ESCALATION_MODEL=GLM-5.2
NEXUSOPS_VISION_MODEL=Qwen2.5-VL-7B-Instruct
NEXUSOPS_EMBEDDING_MODEL=Vietnamese_Embedding
NEXUSOPS_EMBEDDING_FALLBACK_MODEL=multilingual-e5-large
NEXUSOPS_RERANKER_MODEL=bge-reranker-v2-m3
